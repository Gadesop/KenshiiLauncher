<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="AppTheme" parent="@style/Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowBackground">@color/background_app</item>
        <item name="android:statusBarColor">@color/background_status_bar</item>
        <item name="android:navigationBarColor">@color/background_app</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
        <item name="android:textSize">@dimen/_12ssp</item>
    </style>

    <style name="KenifyTitleText" parent="@style/TextAppearance.AppCompat.Title">
        <item name="android:textColor">@color/menu_bar_text</item>
        <item name="android:textSize">@dimen/_20ssp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="KenifySubtitleText" parent="@style/TextAppearance.AppCompat.Body1">
        <item name="android:textColor">@color/primary_text</item>
        <item name="android:textSize">@dimen/_14ssp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="KenifyButtonText" parent="@style/TextAppearance.AppCompat.Button">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.04</item>
    </style>

    <style name="CustomDialogStyle" parent="Theme.AppCompat.Light.Dialog">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
    </style>

    <style name="CustomAlertDialogTheme" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="android:windowBackground">@drawable/dialog_background</item>
        <item name="android:scrollbarThumbHorizontal">@color/background_menu_element</item>
        <item name="android:scrollbarThumbVertical">@color/background_menu_element</item>
    </style>

    <style name="RoundedCornersImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">4%</item>
    </style>

    <style name="RoundImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>
</resources>
